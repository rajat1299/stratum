{
  "name": "@stratum/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Stratum frontend console. Reviewer + operator surfaces.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@stratum/sdk": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tanstack/router-vite-plugin": "^1.95.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20.18.0"
  }
