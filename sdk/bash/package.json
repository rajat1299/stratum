{
  "name": "@stratum/bash",
  "version": "0.0.0",
  "description": "Virtual bash SDK for Stratum workspaces.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest",
    "test:run": "vitest run",
    "test:live": "vitest run tests/live-smoke.test.ts"
  },
  "dependencies": {
    "@stratum/sdk": "0.0.0",
    "just-bash": "^2.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
