{
  "name": "lattice-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-24",
  "containers": [
    {
      "class_name": "LatticeGateway",
      "image": "./Dockerfile"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "LatticeGateway",
        "class_name": "LatticeGateway"
      }
    ]
  },
  "vars": {
    "LATTICE_LISTEN": "0.0.0.0:8080",
    "LATTICE_DATA_DIR": "/data",
    "LATTICE_R2_REGION": "auto",
    "LATTICE_R2_PREFIX": "lattice"
  }
}
