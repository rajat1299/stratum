{
  "name": "stratum-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-24",
  "containers": [
    {
      "class_name": "StratumGateway",
      "image": "./Dockerfile"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "StratumGateway",
        "class_name": "StratumGateway"
      }
    ]
  },
  "vars": {
    "STRATUM_LISTEN": "0.0.0.0:8080",
    "STRATUM_DATA_DIR": "/data",
    "STRATUM_R2_REGION": "auto",
    "STRATUM_R2_PREFIX": "stratum"
  }
}
